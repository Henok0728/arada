# Copy to .env and fill in values. Never commit .env.
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=generate-a-strong-random-key-here

# Database (local Docker default)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/lodge_link

# Test database — used only when running integration tests (tests/integration/)
# Unit tests (tests/unit/) use SQLite in-memory — no PostgreSQL needed.
# Set this to run: pytest backend/tests/integration/ -v
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/lodge_link_test

# Redis (local Docker default)
REDIS_URL=redis://localhost:6379/0

# AfricasTalking SMS Gateway (get from africastalking.com)
AT_USERNAME=sandbox
AT_API_KEY=your-africastalking-api-key
AT_SENDER_ID=LodgeLink

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Platform defaults (do not change without updating region_configs table)
DEFAULT_COUNTRY=ET
DEFAULT_CURRENCY=ETB
