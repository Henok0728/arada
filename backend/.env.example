# Lodge-Link Backend — Environment Variables
# Copy this to .env and fill in real values.
# NEVER commit .env to version control.

# ── Application ────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
DEBUG=false
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_use_openssl_rand_hex_32

# ── Database (PostgreSQL + PostGIS) ───────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/lodge_link

# ── Redis (Celery broker + availability cache) ─────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Security ───────────────────────────────────────────────────────────────
HMAC_SECRET=CHANGE_ME_use_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# ── SMS Gateway (AfricasTalking) ───────────────────────────────────────────
AT_USERNAME=sandbox
AT_API_KEY=your_africas_talking_api_key_here
AT_SENDER_ID=LodgeLink

# ── Platform Defaults ─────────────────────────────────────────────────────
DEFAULT_COUNTRY=ET
DEFAULT_CURRENCY=ETB
REFERRAL_FANOUT_TIMEOUT_SECONDS=3.0
AVAILABILITY_CACHE_TTL_SECONDS=90
